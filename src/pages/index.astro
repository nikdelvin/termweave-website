---
import BaseLayout from '../layouts/BaseLayout.astro';

const githubUrl = 'https://github.com/nikdelvin/termweave';
const installCommand = `mkdir my-termweave-app
cd my-termweave-app
curl -fsSLo install.sh https://raw.githubusercontent.com/nikdelvin/termweave/main/sdk/install.sh
sh install.sh`;

const features = [
  {
    glyph: '⌘',
    token: 'window',
    title: 'A real native window',
    description:
      'Your OpenTUI interface runs inside a resizable Tauri desktop window—not a browser-shaped imitation.',
  },
  {
    glyph: '{}',
    token: 'config',
    title: 'One source of truth',
    description:
      'Set the name, colors, window size, bundle metadata, and icon in a single JSON config.',
  },
  {
    glyph: '↻',
    token: 'reload',
    title: 'Keep your flow',
    description:
      'Edit your Solid interface and see source changes without restarting the native window.',
  },
  {
    glyph: '>_',
    token: 'bundle',
    title: 'One-command bundles',
    description:
      'Turn the same project into a native bundle for the current machine with one build command.',
  },
  {
    glyph: '◫',
    token: 'surface',
    title: 'A small project surface',
    description:
      'Own the interface and product details. Termweave manages the renderer, lifecycle, and packaging.',
  },
  {
    glyph: 'MIT',
    token: 'open',
    title: 'Open by default',
    description:
      'MIT-licensed, inspectable, and ready for issues, ideas, and pull requests from the community.',
  },
];

const workflow = [
  {
    number: '01',
    eyebrow: 'Design',
    title: 'Build your interface',
    description: 'Compose the terminal UI with OpenTUI and Solid in src/App.tsx.',
    code: 'src/App.tsx',
  },
  {
    number: '02',
    eyebrow: 'Configure',
    title: 'Describe the app',
    description: 'Set the native window, colors, identity, and icon in one config file.',
    code: 'app.config.json',
  },
  {
    number: '03',
    eyebrow: 'Ship',
    title: 'Create the bundle',
    description: 'Run a single command and find your native output ready in build/.',
    code: 'bun run build',
  },
];

const prerequisites = ['macOS', 'Bun 1.3+', 'Rust stable', 'Xcode command-line tools'];
const year = new Date().getFullYear();
---

<BaseLayout>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="#top" aria-label="Termweave home">
        <img
          class="brand__mark"
          src="/assets/termweave-weave-mark.png"
          width="512"
          height="512"
          alt=""
        />
        <span class="brand__word">Termweave</span>
      </a>

      <nav class="site-nav" aria-label="Primary navigation">
        <a class="nav-detail" href="#features">Features</a>
        <a class="nav-detail" href="#workflow">Workflow</a>
        <a href="#quick-start">Quick start</a>
        <a class="header-github" href={githubUrl}>
          GitHub <span aria-hidden="true">↗</span>
        </a>
      </nav>
    </div>
  </header>

  <main id="main-content">
    <section class="hero" id="top">
      <div class="hero-mark" aria-hidden="true">
        <img src="/assets/termweave-weave-mark.png" width="512" height="512" alt="" />
      </div>
      <div class="hero-loom" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span><span></span>
      </div>

      <div class="container hero-inner">
        <div class="hero-copy">
          <p class="status-pill">
            <span class="status-dot" aria-hidden="true"></span>
            <span>Open source</span>
            <i aria-hidden="true"></i>
            <span>macOS today</span>
          </p>
          <h1>
            <span class="hero-line">Build terminal apps.</span>
            <span class="hero-line hero-line--gradient">Ship them native.</span>
          </h1>
          <p class="hero-lede">
            Turn an OpenTUI + Solid interface into a real Tauri desktop app—without rebuilding it
            for the web first.
          </p>

          <div class="hero-actions">
            <a class="button button--primary" href="#quick-start">
              Get started
              <span aria-hidden="true">↓</span>
            </a>
            <a class="button button--secondary" href={githubUrl}>
              View on GitHub
              <span aria-hidden="true">↗</span>
            </a>
          </div>

          <div class="hero-stack" aria-label="Termweave stack">
            <span>OpenTUI</span><i aria-hidden="true">×</i><span>Solid</span><i aria-hidden="true"
              >×</i
            ><span>Tauri</span>
          </div>
        </div>

        <div class="hero-stage">
          <div class="stage-kicker" aria-hidden="true">
            <span>01 / Native preview</span>
            <span>Source → desktop</span>
          </div>
          <div class="demo-frame" aria-label="Termweave project demonstration">
            <div class="window-bar">
              <div class="window-dots" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
              <span class="window-title">termweave — native preview</span>
              <span class="window-live"><i aria-hidden="true"></i> live</span>
            </div>
            <div class="demo-media">
              <video
                class="demo-video"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                poster="/assets/termweave-demo-poster.jpg"
                tabindex="-1"
              >
                <source src="/assets/termweave-demo.webm" type="video/webm" />
                <source src="/assets/termweave-demo.mp4" type="video/mp4" />
              </video>
            </div>
            <div class="window-footer" aria-hidden="true">
              <span><i></i> source connected</span>
              <code>⌘ termweave</code>
            </div>
          </div>
          <div class="stage-chip stage-chip--config" aria-hidden="true">
            <code>app.config.json</code>
            <span>one source of truth</span>
          </div>
          <div class="stage-chip stage-chip--bundle" aria-hidden="true">
            <span class="stage-chip__dot"></span>
            <div><strong>Native bundle</strong><span>ready in build/</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="stack-marquee" aria-label="Termweave positioning">
      <div class="stack-marquee__track">
        <div class="stack-marquee__group">
          <span>Terminal-native UI</span><i aria-hidden="true">✦</i>
          <span>Desktop distribution</span><i aria-hidden="true">✦</i>
          <span>Hot source reload</span><i aria-hidden="true">✦</i>
          <span>One focused toolchain</span><i aria-hidden="true">✦</i>
        </div>
        <div class="stack-marquee__group" aria-hidden="true">
          <span>Terminal-native UI</span><i>✦</i>
          <span>Desktop distribution</span><i>✦</i>
          <span>Hot source reload</span><i>✦</i>
          <span>One focused toolchain</span><i>✦</i>
        </div>
      </div>
    </section>

    <section class="section" id="features">
      <div class="container">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Why Termweave</p>
            <h2>The terminal is already the interface.</h2>
          </div>
          <p>
            Keep the keyboard-first experience. Termweave gives it a native window, a product
            identity, and a path to distribution.
          </p>
        </div>

        <div class="feature-grid">
          {
            features.map((feature, index) => (
              <article class={`feature-card feature-card--${index + 1}`}>
                <div class="feature-card__meta">
                  <span>{String(index + 1).padStart(2, '0')} / 06</span>
                  <code>{feature.token}</code>
                </div>
                <span class="feature-card__glyph" aria-hidden="true">
                  {feature.glyph}
                </span>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section workflow-section" id="workflow">
      <div class="container">
        <div class="workflow-intro">
          <div>
            <p class="eyebrow">Three moves. One app.</p>
            <h2>Your app in.<br />Native bundle out.</h2>
          </div>
          <div class="managed-list">
            <div>
              <span>You own</span>
              <code>src/App.tsx</code>
              <code>app.config.json</code>
              <code>app.icon.svg</code>
            </div>
            <div class="managed-list__termweave">
              <span>Termweave manages</span>
              <code>window + renderer</code>
              <code>lifecycle + reload</code>
              <code>native packaging</code>
            </div>
          </div>
        </div>

        <div class="workflow-grid">
          {
            workflow.map((step) => (
              <article class="workflow-card">
                <div class="workflow-card__top">
                  <span>{step.number}</span>
                  <p>{step.eyebrow}</p>
                </div>
                <div class="workflow-card__rail" aria-hidden="true">
                  <span />
                </div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
                <code>{step.code}</code>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section quick-start-section" id="quick-start">
      <div class="quick-start-mark" aria-hidden="true">
        <img src="/assets/termweave-weave-mark.png" width="512" height="512" alt="" />
      </div>
      <div class="container quick-start">
        <div class="quick-start__heading">
          <div>
            <p class="eyebrow">Quick start</p>
            <h2>Four commands.<br />One native window.</h2>
          </div>
          <div class="quick-start__intro">
            <p>
              Run the installer, answer a few project questions, and Termweave will create the
              starter and install everything it manages.
            </p>
            <ul class="prerequisite-list" aria-label="Prerequisites">
              {prerequisites.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>

        <div class="terminal-card" data-command={installCommand}>
          <div class="terminal-card__bar">
            <div class="terminal-card__title">
              <span class="terminal-card__traffic" aria-hidden="true"><i></i><i></i><i></i></span>
              <span>Install Termweave</span>
            </div>
            <button class="copy-button" type="button" data-copy-command>
              <span data-copy-label>Copy</span>
              <span aria-hidden="true">⌘C</span>
            </button>
          </div>
          <pre
            id="install-command"
            aria-label="Termweave installation command"><code>
            {
              installCommand
                .split('\n')
                .map((line) => <span class="command-line">{line}</span>)
            }
          </code></pre>
          <div class="terminal-card__next">
            <span><i aria-hidden="true"></i> Ready for first launch</span>
            <code>$ bun run dev</code>
          </div>
          <p class="sr-only" role="status" aria-live="polite" data-copy-status></p>
        </div>

        <aside class="platform-note">
          <span aria-hidden="true">⌘</span>
          <div>
            <strong>macOS is the current target</strong>
            <p>Installation, development, and native bundles currently target macOS.</p>
          </div>
          <a href={githubUrl}>Follow platform work <span aria-hidden="true">↗</span></a>
        </aside>
      </div>
    </section>

    <section class="closing-section">
      <div class="container closing-card">
        <div class="closing-copy">
          <p class="eyebrow">Your terminal app belongs on the desktop.</p>
          <h2>Stop shipping the terminal as an afterthought.</h2>
          <p>
            Build the focused, keyboard-first product only a terminal interface can be—and ship it
            as a native app.
          </p>
        </div>
        <div class="closing-actions">
          <a class="button button--primary" href={githubUrl}>
            Star on GitHub <span aria-hidden="true">↗</span>
          </a>
          <a class="text-link" href={`${githubUrl}/blob/main/CONTRIBUTING.md`}>
            Contributing guide <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="closing-mark" aria-hidden="true">
          <img src="/assets/termweave-weave-mark.png" width="auto" height="auto" alt="" />
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <a class="footer-brand" href="#top">
        <img src="/assets/termweave-weave-mark.png" width="34" height="34" alt="" />
        <span>Termweave</span>
      </a>
      <p>MIT © {year} Nikita Stadnik</p>
      <div class="footer-links">
        <a href={githubUrl}>Source</a>
        <a href="https://nikdelv.in">nikdelv.in</a>
      </div>
    </div>
  </footer>

  <script>
    const copyButton = document.querySelector<HTMLButtonElement>('[data-copy-command]');
    const copyLabel = document.querySelector<HTMLElement>('[data-copy-label]');
    const copyStatus = document.querySelector<HTMLElement>('[data-copy-status]');
    const terminalCard = document.querySelector<HTMLElement>('.terminal-card');
    const command = terminalCard?.dataset.command ?? '';

    copyButton?.addEventListener('click', async () => {
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(command);
        } else {
          const commandElement = document.querySelector<HTMLElement>('#install-command');
          const selection = window.getSelection();

          if (!commandElement || !selection) throw new Error('Selection unavailable');

          const range = document.createRange();
          range.selectNodeContents(commandElement);
          selection.removeAllRanges();
          selection.addRange(range);

          if (copyLabel) copyLabel.textContent = 'Selected';
          if (copyStatus)
            copyStatus.textContent = 'Installation command selected. Copy it manually.';
          return;
        }

        if (copyLabel) copyLabel.textContent = 'Copied';
        if (copyStatus) copyStatus.textContent = 'Installation command copied.';

        window.setTimeout(() => {
          if (copyLabel) copyLabel.textContent = 'Copy';
        }, 1800);
      } catch {
        if (copyLabel) copyLabel.textContent = 'Select';
        if (copyStatus) {
          copyStatus.textContent = 'Select the installation command and copy it manually.';
        }
      }
    });

    const motionPreference = window.matchMedia('(prefers-reduced-motion: reduce)');
    const demoVideo = document.querySelector<HTMLVideoElement>('.demo-video');

    const syncVideoMotion = () => {
      if (!demoVideo) return;

      if (motionPreference.matches) {
        demoVideo.pause();
        demoVideo.removeAttribute('autoplay');
      } else {
        demoVideo.setAttribute('autoplay', '');
        demoVideo.play().catch(() => {});
      }
    };

    syncVideoMotion();
    motionPreference.addEventListener('change', syncVideoMotion);
  </script>
</BaseLayout>
