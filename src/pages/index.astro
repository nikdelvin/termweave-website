---
import BaseLayout from '../layouts/BaseLayout.astro';

const githubUrl = 'https://github.com/nikdelvin/termweave';
const installCommand = `mkdir my-termweave-app
cd my-termweave-app
curl -fsSLo install.sh https://raw.githubusercontent.com/nikdelvin/termweave/main/sdk/install.sh
sh install.sh`;

const features = [
  {
    token: 'window',
    title: 'A real native window',
    description:
      'Your OpenTUI interface runs inside a resizable Tauri desktop window—not a browser-shaped imitation.',
  },
  {
    token: 'config',
    title: 'One source of truth',
    description:
      'Set the name, colors, window size, bundle metadata, and icon in a single JSON config.',
  },
  {
    token: 'reload',
    title: 'Keep your flow',
    description:
      'Edit your Solid interface and see source changes without restarting the native window.',
  },
  {
    token: 'bundle',
    title: 'One-command bundles',
    description:
      'Turn the same project into a native bundle for the current machine with one build command.',
  },
  {
    token: 'surface',
    title: 'A small project surface',
    description:
      'Own the interface and product details. Termweave manages the renderer, lifecycle, and packaging.',
  },
  {
    token: 'open',
    title: 'Open by default',
    description:
      'MIT-licensed, inspectable, and ready for issues, ideas, and pull requests from the community.',
  },
];

const workflow = [
  {
    number: '01',
    eyebrow: 'Design',
    title: 'Build your interface',
    description: 'Compose the terminal UI with OpenTUI and Solid in src/App.tsx.',
    code: 'src/App.tsx',
  },
  {
    number: '02',
    eyebrow: 'Configure',
    title: 'Describe the app',
    description: 'Set the native window, colors, identity, and icon in one config file.',
    code: 'app.config.json',
  },
  {
    number: '03',
    eyebrow: 'Ship',
    title: 'Create the bundle',
    description: 'Run a single command and find your native output ready in build/.',
    code: 'bun run build',
  },
];

const prerequisites = ['macOS', 'Bun 1.3+', 'Rust stable', 'Xcode command-line tools'];
const year = new Date().getFullYear();
---

<BaseLayout>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="#top" aria-label="Termweave home">
        <img
          class="brand__mark"
          src="/assets/termweave-weave-mark.png"
          width="512"
          height="512"
          alt=""
        />
        <span class="brand__word">Termweave</span>
      </a>

      <nav class="site-nav" aria-label="Primary navigation">
        <a class="nav-detail" href="#features">Features</a>
        <a class="nav-detail" href="#workflow">Workflow</a>
        <a href="#quick-start">Quick start</a>
        <a class="header-github" href={githubUrl}>
          GitHub <span aria-hidden="true">↗</span>
        </a>
      </nav>
    </div>
  </header>

  <main id="main-content">
    <section class="hero" id="top">
      <div class="hero-thread hero-thread--one" aria-hidden="true"></div>
      <div class="hero-thread hero-thread--two" aria-hidden="true"></div>
      <div class="hero-thread hero-thread--three" aria-hidden="true"></div>
      <div class="hero-thread hero-thread--four" aria-hidden="true"></div>

      <div class="container hero-inner">
        <div class="hero-copy">
          <p class="status-pill">
            <span class="status-dot" aria-hidden="true"></span>
            Open source · Built for macOS
          </p>
          <h1>
            <span class="hero-line hero-line--teal">Build terminal apps.</span>
            <span class="hero-line hero-line--indigo">Ship them native.</span>
          </h1>
          <p class="hero-lede">
            Termweave turns OpenTUI + Solid interfaces into native Tauri desktop apps. You build the
            experience; Termweave handles the window, renderer, lifecycle, and packaging.
          </p>

          <div class="hero-actions">
            <a class="button button--primary" href="#quick-start">
              Get started
              <span aria-hidden="true">↓</span>
            </a>
            <a class="button button--secondary" href={githubUrl}>
              View on GitHub
              <span aria-hidden="true">↗</span>
            </a>
          </div>

          <ul class="stack-list" aria-label="Built with">
            <li><span aria-hidden="true">◆</span> OpenTUI</li>
            <li><span aria-hidden="true">◆</span> Solid</li>
            <li><span aria-hidden="true">◆</span> Tauri</li>
          </ul>
        </div>

        <div class="demo-frame" aria-label="Termweave project demonstration">
          <div class="window-bar">
            <div class="window-dots" aria-hidden="true">
              <span></span><span></span><span></span>
            </div>
            <span class="window-title">termweave — native preview</span>
            <span class="window-live"><i aria-hidden="true"></i> live</span>
          </div>
          <video
            class="demo-video"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="/assets/termweave-demo-poster.jpg"
            tabindex="-1"
          >
            <source src="/assets/termweave-demo.webm" type="video/webm" />
            <source src="/assets/termweave-demo.mp4" type="video/mp4" />
          </video>
          <div class="window-footer" aria-hidden="true">
            <span><i></i> source connected</span>
            <code>⌘ termweave</code>
          </div>
        </div>
      </div>
    </section>

    <section class="stack-marquee" aria-label="Termweave positioning">
      <div class="container stack-marquee__inner">
        <span>Terminal-native UI</span>
        <i aria-hidden="true"></i>
        <span>Desktop distribution</span>
        <i aria-hidden="true"></i>
        <span>One focused toolchain</span>
      </div>
    </section>

    <section class="section" id="features">
      <div class="container">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Why Termweave</p>
            <h2>The terminal is your interface.<br />The desktop is the delivery.</h2>
          </div>
          <p>
            Stop rebuilding terminal interactions with web-shaped primitives. Keep the
            keyboard-first experience—and give it a native home.
          </p>
        </div>

        <div class="feature-grid">
          {
            features.map((feature, index) => (
              <article class="feature-card">
                <div class="feature-card__meta">
                  <code>{feature.token}</code>
                  <span>{String(index + 1).padStart(2, '0')}</span>
                </div>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section workflow-section" id="workflow">
      <div class="container">
        <div class="workflow-intro">
          <div>
            <p class="eyebrow">Three moves. One app.</p>
            <h2>Own the product.<br />Let the toolchain disappear.</h2>
          </div>
          <div class="managed-list">
            <div>
              <span>You own</span>
              <code>src/App.tsx</code>
              <code>app.config.json</code>
              <code>app.icon.svg</code>
            </div>
            <div class="managed-list__termweave">
              <span>Termweave manages</span>
              <code>window + renderer</code>
              <code>lifecycle + reload</code>
              <code>native packaging</code>
            </div>
          </div>
        </div>

        <div class="workflow-grid">
          {
            workflow.map((step) => (
              <article class="workflow-card">
                <div class="workflow-card__top">
                  <span>{step.number}</span>
                  <p>{step.eyebrow}</p>
                </div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
                <code>{step.code}</code>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section quick-start-section" id="quick-start">
      <div class="container quick-start">
        <div class="quick-start__copy">
          <p class="eyebrow">Quick start</p>
          <h2>From empty folder<br />to native window.</h2>
          <p>
            Run the installer, answer a few project questions, and Termweave will create the starter
            and install everything it manages.
          </p>

          <ul class="prerequisite-list" aria-label="Prerequisites">
            {prerequisites.map((item) => <li>{item}</li>)}
          </ul>

          <aside class="platform-note">
            <span aria-hidden="true">⌘</span>
            <div>
              <strong>Current platform status</strong>
              <p>Installation, development, and native bundles currently target macOS.</p>
            </div>
          </aside>
        </div>

        <div class="terminal-card">
          <div class="terminal-card__bar">
            <span>Install Termweave</span>
            <button class="copy-button" type="button" data-copy-command>
              <span data-copy-label>Copy</span>
              <span aria-hidden="true">⌘C</span>
            </button>
          </div>
          <pre><code id="install-command">{installCommand}</code></pre>
          <div class="terminal-card__next">
            <span>Then launch your app</span>
            <code>bun run dev</code>
          </div>
          <p class="sr-only" role="status" aria-live="polite" data-copy-status></p>
        </div>
      </div>
    </section>

    <section class="closing-section">
      <div class="container closing-card">
        <div class="closing-mark" aria-hidden="true">
          <img src="/assets/termweave-weave-mark.png" width="112" height="112" alt="" />
        </div>
        <div>
          <p class="eyebrow">Your terminal app belongs on the desktop.</p>
          <h2>Build the thing only a terminal interface can be.</h2>
        </div>
        <div class="closing-actions">
          <a class="button button--primary" href={githubUrl}>
            Star on GitHub <span aria-hidden="true">↗</span>
          </a>
          <a class="text-link" href={`${githubUrl}/blob/main/CONTRIBUTING.md`}>
            Contributing guide <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <a class="footer-brand" href="#top">
        <img src="/assets/termweave-weave-mark.png" width="34" height="34" alt="" />
        <span>Termweave</span>
      </a>
      <p>MIT © {year} Nikita Stadnik</p>
      <div class="footer-links">
        <a href={githubUrl}>Source</a>
        <a href="https://nikdelv.in">nikdelv.in</a>
      </div>
    </div>
  </footer>

  <script>
    const copyButton = document.querySelector<HTMLButtonElement>('[data-copy-command]');
    const copyLabel = document.querySelector<HTMLElement>('[data-copy-label]');
    const copyStatus = document.querySelector<HTMLElement>('[data-copy-status]');
    const command = document.querySelector<HTMLElement>('#install-command')?.textContent ?? '';

    copyButton?.addEventListener('click', async () => {
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(command);
        } else {
          const commandElement = document.querySelector<HTMLElement>('#install-command');
          const selection = window.getSelection();

          if (!commandElement || !selection) throw new Error('Selection unavailable');

          const range = document.createRange();
          range.selectNodeContents(commandElement);
          selection.removeAllRanges();
          selection.addRange(range);

          if (copyLabel) copyLabel.textContent = 'Selected';
          if (copyStatus)
            copyStatus.textContent = 'Installation command selected. Copy it manually.';
          return;
        }

        if (copyLabel) copyLabel.textContent = 'Copied';
        if (copyStatus) copyStatus.textContent = 'Installation command copied.';

        window.setTimeout(() => {
          if (copyLabel) copyLabel.textContent = 'Copy';
        }, 1800);
      } catch {
        if (copyLabel) copyLabel.textContent = 'Select';
        if (copyStatus) {
          copyStatus.textContent = 'Select the installation command and copy it manually.';
        }
      }
    });

    const motionPreference = window.matchMedia('(prefers-reduced-motion: reduce)');
    const demoVideo = document.querySelector<HTMLVideoElement>('.demo-video');

    const syncVideoMotion = () => {
      if (!demoVideo) return;

      if (motionPreference.matches) {
        demoVideo.pause();
        demoVideo.removeAttribute('autoplay');
      } else {
        demoVideo.setAttribute('autoplay', '');
        demoVideo.play().catch(() => {});
      }
    };

    syncVideoMotion();
    motionPreference.addEventListener('change', syncVideoMotion);
  </script>
</BaseLayout>
